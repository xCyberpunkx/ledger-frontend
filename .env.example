# Database (matches docker-compose.yml service)
DATABASE_URL="postgresql://ledger:ledger_dev_password@localhost:5432/ledger_dev?schema=public"

# App
PORT=4000
NODE_ENV=development

# Auth (Clerk) — get these from your Clerk dashboard (dashboard.clerk.com)
CLERK_SECRET_KEY="sk_test_xxxxxxxx"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxx"

# Email (Resend) — used for verification, password reset, activity notifications
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Ledger <noreply@yourdomain.com>"

# Files (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Frontend origin (CORS)
FRONTEND_URL="http://localhost:3000"

# Monitoring
SENTRY_DSN=""
